// Per-environment secrets and deployment mode
// ⚠️  This file (app-secret.conf) is GITIGNORED — never commit it.
//
// Instructions:
//   1. Copy this template: cp site/webapp/app-secret.conf.tmpl site/webapp/app-secret.conf
//   2. Replace all FIXME values with real settings for this environment
//   3. For development: the minimal requirement is deployment.mode and session.secret
//   4. For production: all fields below are required
//
// This file is deep-merged on top of site/webapp/app.conf at startup.
// Only fields that differ from site/webapp/app.conf need to be set here.
{
    // Deployment mode for this environment: 'dev' or 'prod'
    deployment: {
        mode:   'FIXME'     // 'dev' for local development, 'prod' for production
    },

    // Session secret — must be a long random string, unique per environment
    middleware: {
        session: {
            secret: 'FIXME-CHANGE-TO-A-LONG-RANDOM-STRING',
            cookie: {
                // Set to true in production (requires HTTPS); false for local HTTP dev
                secure: false
            }
        }
    },

    // Database authentication (required for production; omit for local dev without auth)
    database: {
        standalone: {
            options: {
                authSource: 'jp-prod',      // match deployment.prod.db in app.conf
                auth: {
                    username:   'FIXME',
                    password:   'FIXME'
                }
            }
        }
    },

    // Redis passwords (leave empty string '' if Redis has no auth)
    redis: {
        single: {
            password:   'FIXME'
        },
        cluster: {
            password:   'FIXME'
        }
    }
}

// EOF site/webapp/app-secret.conf.tmpl
