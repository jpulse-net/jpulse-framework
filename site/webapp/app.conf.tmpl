// Site-specific configuration overrides
// This file is committed to the repository and shared across all environments.
// It MUST NOT contain secrets or environment-specific settings.
//
// Per-environment secrets and deployment mode go in site/webapp/app-secret.conf
// (gitignored). See site/webapp/app-secret.conf.tmpl for the template.
//
// Default behavior without app-secret.conf:
//   - deployment.mode defaults to 'dev' (safe fallback)
//   - npm start works with zero extra setup for local development
{
    app: {
        site: {
            name:       'My jPulse Framework Site',
            shortName:  'My jPulse Site',
            copyright:  '© 1970 My Company',
            version:    '0.1.0',
            release:    '1970-01-01',
            logoUrl:    '/images/jpulse-logo/jpulse-logo-reverse.svg',
            logoAlt:    'jPulse'
        },
        customField:    'The sky is the limit!',
        customFlag:     true
    },

    // deployment.mode is in site/webapp/app-secret.conf (per-environment)
    // Both dev and prod sections are here so the same app.conf works for all environments
    deployment: {
        mode:   'dev',          // safe default; prod overrides to 'prod' in app-secret.conf
        dev: {
            name:       'development',
            db:         'jp-dev',
            port:       8080
        },
        prod: {
            name:       'production',
            db:         'jp-prod',
            port:       8081
        }
    },

    // Dev-safe session secret — overridden in app-secret.conf for production
    // This placeholder allows npm start to work in dev without any extra setup
    middleware: {
        session: {
            secret:     'dev-only-insecure-do-not-use-in-production',
            touchAfter: 3600    // session touch interval in seconds
        }
    },

    // Redis configuration (passwords are in site/webapp/app-secret.conf)
    redis: {
        enabled:    true,
        mode:       'single',   // use 'cluster' for HA production deployments

        single: {
            host:   'localhost',
            port:   6379
        }
    },

    // Site-specific features
    features: {
        customDashboard:    true,
        siteAnalytics:      true,
        customTheme:        'blue'
    }
}

// EOF site/webapp/app.conf.tmpl
