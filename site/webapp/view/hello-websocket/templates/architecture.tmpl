/api/1/ws/hello-emoji    ← Emoji cursor (ephemeral, no persistence)
/api/1/ws/hello-todo     ← Collaborative todo (Pattern A: REST + WS sync)
/api/1/ws/hello-notes    ← Sticky notes (Pattern B: WS for CRUD, Redis store)

// Generic examples
/api/1/ws/chat           ← Chat messages
/api/1/ws/notifications  ← System notifications

// Different authentication requirements
/api/1/ws/public-chat         requireAuth: false
/api/1/ws/admin-dashboard     requireAuth: true, requireRoles: ['admin']</code></pre>
        </div>

        <p class="jp-mt-15">
            <strong>Benefits:</strong>
        </p>
        <ul class="jp-list">
            <li>Separate concerns (chat vs notifications vs dashboards)</li>
            <li>Independent authentication requirements</li>
            <li>Granular statistics and monitoring per namespace</li>
            <li>Easy to add/remove features without affecting others</li>
        </ul>
    </div>

    <!-- Message Flow Patterns -->
    <div class="jp-card jp-mt-30">
        <h3>📬 Message Flow Patterns</h3>

        <div class="local-panel">
            <h4 class="jp-m-0">Pattern 1: Broadcast to All</h4>
            <pre class="local-panel-pre local-panel-pre-compact jp-mt-15"><code>// Server: pass ctx (e.g. conn.ctx) for logging and Redis relay
ns.broadcast({
    type: 'notification',
    data: { message: 'New feature released!' }
}, ctx);

// Client: single-arg onMessage(message), message.success, message.data
ws.onMessage((message) => {
    if (message.success) {
        const payload = message.data ?? {};
        if (payload.type === 'notification') showNotification(payload.data?.message);
    }
});</code></pre>
        </div>

        <div class="local-panel">
            <h4 class="jp-m-0">Pattern 2: Send to Specific Client</h4>
            <pre class="local-panel-pre local-panel-pre-compact jp-mt-15"><code>// Server: pass ctx (e.g. conn.ctx)
ns.sendToClient(clientId, {
    type: 'private-message',
    data: { message: 'Just for you!' }
}, ctx);</code></pre>
        </div>

        <div class="local-panel">
            <h4 class="jp-m-0">Pattern 3: REST API + WebSocket Hybrid (Pattern A)</h4>
            <pre class="local-panel-pre local-panel-pre-compact jp-mt-15"><code>// Server: broadcast with ctx = null when called from REST (no connection)
ns.broadcast({ type: 'todo-created', data: { todo, username } }, null);

// Client
ws.onMessage((message) => {
    if (message.success) {
        const payload = message.data ?? {};
        if (payload.type === 'todo-created') addTodoToList(payload.data?.todo);
    }
});</code></pre>
        </div>

        <div class="local-panel">
            <h4 class="jp-m-0">Pattern 4: WebSocket for CRUD (Pattern B)</h4>
            <pre class="local-panel-pre local-panel-pre-compact jp-mt-15"><code>// Client
ws.send({ type: 'note-create', x, y, text, username: notesUsername() });

// Server: conn = { clientId, message, ctx }; pass conn.ctx to broadcast
notes.onMessage(async ({ clientId, message: data, ctx }) => {
    const username = ctx?.username || 'guest';
    const note = await this._notesCreate(...);
    notes.broadcast({ type: 'note-created', data: { note, username } }, ctx);
});</code></pre>
            <p class="jp-help-text jp-mt-10 jp-mb-0">
                Use for live collaborative UIs (canvas, sticky boards). Server stores in Redis so all instances share state.
            </p>
            <p class="jp-help-text jp-mt-10 jp-mb-0 jp-output jp-output-warning jp-p-10">
                ⚠️ <strong>Gotcha:</strong> The sender also receives the broadcast. If you apply every <code>note-updated</code> to local state, your own (stale) echo can overwrite the textarea while the user is typing and drop characters — worse under load or in a cluster. Ignore incoming <code>note-updated</code> for a note when you have pending debounced input for that note (<code>textDebounce[noteId]</code>).
            </p>
        </div>
