// Development secrets configuration
// ⚠️  app-secret.conf is GITIGNORED — never commit it.
// For most dev setups this file is not needed — npm start works without it.
// Create this file only if you need to override dev defaults (e.g. non-empty Redis password).
{
    deployment: {
        mode:   'dev'
    },

    middleware: {
        session: {
            secret: '%SESSION_SECRET%',
            cookie: {
                secure: false   // HTTP OK for development
            }
        }
    },

    // Redis password (leave empty '' if Redis has no auth)
    redis: {
        single: {
            password:   '%REDIS_PASSWORD%'
        }
    }
}

// EOF site/webapp/app-secret.conf
