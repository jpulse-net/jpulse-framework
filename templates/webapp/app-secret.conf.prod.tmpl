// Production secrets configuration — generated by npx jpulse configure
// ⚠️  app-secret.conf is GITIGNORED — never commit it.
// This file is deep-merged on top of site/webapp/app.conf at startup.
{
    deployment: {
        mode:   'prod'
    },

    middleware: {
        session: {
            secret: '%SESSION_SECRET%',
            cookie: {
                secure:     true,   // HTTPS required in production
                httpOnly:   true,
                sameSite:   'strict'
            }
        }
    },

    database: {
        standalone: {
            options: {
                authSource: '%DB_NAME%',
                auth: {
                    username:   '%DB_USER%',
                    password:   '%DB_PASS%'
                }
            }
        }
    },

    // Redis passwords
    redis: {
        single: {
            password:   '%REDIS_PASSWORD%'
        },
        cluster: {
            password:   '%REDIS_PASSWORD%'
        }
    }
}

