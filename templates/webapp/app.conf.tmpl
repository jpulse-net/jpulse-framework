// Site configuration — generated by npx jpulse configure
// This file is safe to commit. It does not contain secrets.
// Per-environment secrets and deployment mode are in site/webapp/app-secret.conf (gitignored).
//
// Default behavior without app-secret.conf:
//   deployment.mode defaults to 'dev' — npm start works with zero extra setup for dev
{
    app: {
        site: {
            name:       '%SITE_NAME%',
            shortName:  '%SITE_SHORT_NAME%'
        },
        siteId:     '%JPULSE_SITE_ID%',
        domainName: '%JPULSE_DOMAIN_NAME%'
    },

    // deployment.mode is in site/webapp/app-secret.conf (per-environment)
    // Both sections are here so the same app.conf works for all environments
    deployment: {
        mode:   'dev',          // safe default; prod overrides to 'prod' in app-secret.conf
        dev: {
            name:   'development',
            db:     '%DB_NAME_DEV%',
            port:   8080
        },
        prod: {
            name:   'production',
            db:     '%DB_NAME%',
            port:   %PORT%
        }
    },

    // Dev-safe session secret — overridden by real secret in app-secret.conf for production
    middleware: {
        session: {
            secret: 'dev-only-insecure-do-not-use-in-production'
        }
    },

    database: {
        mode: 'standalone'
    },

    // Redis topology (passwords are in site/webapp/app-secret.conf)
    redis: {
        enabled:    true,
        mode:       '%REDIS_MODE%',
        single: {
            host:   '%REDIS_HOST%',
            port:   %REDIS_PORT%
        },
        cluster: {
            nodes:  %REDIS_CLUSTER_NODES%
        }
    }
}

// EOF site/webapp/app.conf
