{{#component "userSpa.meHtml"}}
{{#if user.isAuthenticated}}
    <div class="jp-page-header">
        <h1>{{i18n.view.user.me.title}}</h1>
        <div class="local-settings-header-info">
            <div class="jp-user-avatar local-header-avatar" id="meAvatarHeader">{{user.initials}}</div>
            <span class="local-header-name" id="meNameHeader">{{user.firstName}} {{user.lastName}}</span>
            <span class="jp-status-badge jp-status-{{user.status}} local-header-status" id="meStatusHeader">{{user.status}}</span>
        </div>
    </div>

    <!-- User Stats -->
    <div class="jp-stats-grid" id="userStatsGrid">
        <div class="jp-stat-card">
            <div class="jp-stat-number" id="lastLogin">-</div>
            <div class="jp-stat-label">{{i18n.view.user.me.lastLogin}}</div>
        </div>
        <div class="jp-stat-card">
            <div class="jp-stat-number" id="accountStatus">-</div>
            <div class="jp-stat-label">{{i18n.view.user.me.accountStatus}}</div>
        </div>
        <div class="jp-stat-card">
            <div class="jp-stat-number" id="memberSince">-</div>
            <div class="jp-stat-label">{{i18n.view.user.me.memberSince}}</div>
        </div>
    </div>

    <!-- Navigation Cards -->
    <div class="jp-dashboard-grid">
        <a href="/user/settings" class="jp-card-dashboard jp-icon-btn">
            <div class="jp-icon-container">
                {{components.jpIcons.userSvg size="64" _inline=true}}
            </div>
            <h3 class="jp-card-title">{{i18n.view.user.me.settings}}</h3>
            <p class="jp-card-description">{{i18n.view.user.me.settingsDesc}}</p>
        </a>

        {{#if user.isAdmin}}
        <a href="/admin/" class="jp-card-dashboard jp-icon-btn">
            <div class="jp-icon-container">
                {{components.jpIcons.configSvg size="64"}}
            </div>
            <h3 class="jp-card-title">{{i18n.view.user.me.adminDashboard}}</h3>
            <p class="jp-card-description">{{i18n.view.user.me.adminDashboardDesc}}</p>
        </a>
        {{/if}}
    </div>
{{else}}
    <div class="jp-error-box local-error-box">
        {{i18n.view.auth.common.notAuthenticated}}
    </div>
{{/if}}
{{/component}}
{{#component "userSpa.meJs"}}
{{#if user.isAuthenticated}}
    // W-134: Me page initialization function (called by SPA router)
    async function initMe() {
        await loadMeUserData();
    }

    async function loadMeUserData() {
        try {
            const result = await jPulse.api.get('/api/1/user');
            if (result.success && result.data) {
                const user = result.data;
                const firstName = user.profile?.firstName || '';
                const lastName = user.profile?.lastName || '';
                const initials = ((firstName[0] || '') + (lastName[0] || '')).toUpperCase();
                const fullName = [firstName, lastName].filter(Boolean).join(' ');
                const status = user.status || '';

                // Update last login
                const lastLoginEl = document.getElementById('lastLogin');
                if (lastLoginEl) {
                    if (user.lastLogin) {
                        const date = new Date(user.lastLogin);
                        lastLoginEl.textContent = date.toISOString().split('T')[0];
                    } else {
                        lastLoginEl.textContent = '{{i18n.view.user.me.never}}';
                    }
                }

                // Update account status stat card
                const statusEl = document.getElementById('accountStatus');
                if (statusEl) {
                    statusEl.textContent = status || '{{i18n.view.user.me.unknown}}';
                }

                // Update member since
                const memberSinceEl = document.getElementById('memberSince');
                if (memberSinceEl) {
                    if (user.createdAt) {
                        const date = new Date(user.createdAt);
                        memberSinceEl.textContent = date.toISOString().split('T')[0];
                    } else {
                        memberSinceEl.textContent = '{{i18n.view.user.me.unknown}}';
                    }
                }

                // Update page-header user info
                const avatarHeader = document.getElementById('meAvatarHeader');
                if (avatarHeader) avatarHeader.textContent = initials || avatarHeader.textContent;
                const nameHeader = document.getElementById('meNameHeader');
                if (nameHeader) nameHeader.textContent = fullName;
                const statusHeader = document.getElementById('meStatusHeader');
                if (statusHeader) {
                    statusHeader.textContent = status;
                    statusHeader.className = `jp-status-badge${status ? ` jp-status-${status}` : ''} local-header-status`;
                }
            }
        } catch (error) {
            console.error('- jPulse: Failed to load user data:', error);
        }
    }
{{/if}}
{{/component}}

<!-- EOF webapp/view/user/me.tmpl -->
