 * @genai           65%, Cursor 2.5, Claude Sonnet 4.6
--}}
{{#component "userSpa.settingsHtml"}}
{{#if user.isAuthenticated}}
    <div class="local-user-profile">
        <!-- W-171: jp-page-header: title left, user info right -->
        <div class="jp-page-header">
            <h1>⚙ {{i18n.view.user.settings.title}}</h1>
            <div class="local-settings-header-info">
                <div class="jp-user-avatar local-header-avatar" id="settingsAvatarHeader">{{user.initials}}</div>
                <span class="local-header-name" id="settingsNameHeader">{{user.firstName}} {{user.lastName}}</span>
                <span class="jp-status-badge jp-status-{{user.status}} local-header-status" id="settingsStatusHeader">{{user.status}}</span>
            </div>
        </div>

        <!-- W-171: Built-in tab panels (moved into .jp-tabs-panels by tabs.register()) -->

        <!-- W-175: Panel: Profile (content built by renderCoreSchemaBlock()) -->
        <div id="panel-profile" class="jp-panel"></div>

        <!-- W-175: Panel: Preferences (content built by renderCoreSchemaBlock(); selects populated by load*()) -->
        <div id="panel-preferences" class="jp-panel"></div>

        <!-- Panel: Security (password fields always visible; no collapsible) -->
        <div id="panel-security" class="jp-panel">
            <div class="jp-card jp-schema-section">
                <div class="jp-info-box">
                    <p>{{i18n.view.user.settings.securityNote}}</p>
                </div>
                <div id="passwordFields" class="jp-password-form">
                    <div class="jp-form-group">
                        <label for="currentPassword" class="jp-form-label">{{i18n.view.user.settings.currentPassword}}</label>
                        <input type="password" id="currentPassword" name="currentPassword" class="jp-form-input" autocomplete="off">
                    </div>
                    <div class="jp-form-grid">
                        <div class="jp-form-group">
                            <label for="newPassword" class="jp-form-label">{{i18n.view.user.settings.newPassword}}</label>
                            <input type="password" id="newPassword" name="newPassword" class="jp-form-input" autocomplete="new-password">
                        </div>
                        <div class="jp-form-group">
                            <label for="confirmPassword" class="jp-form-label">{{i18n.view.user.settings.confirmPassword}}</label>
                            <input type="password" id="confirmPassword" name="confirmPassword" class="jp-form-input" autocomplete="new-password">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Plugin panels staging area (panels created by JS, then moved into .jp-tabs-panels by register()) -->
        <div id="settingsPluginPanels"></div>

        <!-- W-171: Tab container (populated by JS via jPulse.UI.tabs.register()) -->
        <div id="settingsTabs"></div>

        <div class="jp-btn-group">
            <a href="/user/me" class="jp-btn jp-btn-secondary" id="backBtn">{{i18n.view.user.settings.back}}</a>
            <button id="discardBtn" class="jp-btn jp-btn-secondary" onclick="revertChanges()" disabled>{{i18n.view.user.settings.discard}}</button>
            <button id="saveBtn" class="jp-btn jp-btn-success" onclick="saveProfile()" disabled>{{i18n.view.user.settings.save}}</button>
        </div>
    </div>
{{else}}
    <div class="jp-error-box">
        {{i18n.view.auth.common.notAuthenticated}}
    </div>
{{/if}}
{{/component}}
{{#component "userSpa.settingsJs"}}
{{#if user.isAuthenticated}}
    // W-134: Settings page initialization function (called by SPA router)
    // W-161: Single mode (always edit); originalValues set after load for revert/change detection
    // W-171: Tabs interface; settingsTabsHandle tracks registration; skip rebuild on re-navigation
    async function initSettings() {
        const isFirstInit = (settingsTabsHandle === null);

        await loadSettingsProfile();
        await loadSettingsLanguages();
        await loadSettingsThemes();

        if (isFirstInit) {
            settingsTabsHandle = buildSettingsTabs();
            const tabsEl = document.getElementById('settingsTabs');
            if (tabsEl) jPulse.UI.input.initAll(tabsEl);
        }

        // W-161: Baseline for revert and unsaved-changes detection (always-edit mode)
        originalValues = JSON.parse(JSON.stringify(getCurrentFormValues()));
        // W-175: use data-path selector for theme select
        const themeSelectForBaseline = document.querySelector('[data-path="preferences.theme"]');
        originalThemePreview = document.documentElement.getAttribute('data-theme') || (themeSelectForBaseline?.value || 'light');

        // W-129/W-175: Theme preview is handled via delegated change handler below.
        // This is robust across SPA re-navigation and tab/panel re-parenting.

        // Expose dirty getter for SPA router (index.shtml) so in-user navigation can prompt before leaving
        if (typeof window.jPulse === 'undefined') window.jPulse = {};
        if (typeof window.jPulse.userSpa === 'undefined') window.jPulse.userSpa = {};
        window.jPulse.userSpa.getSettingsDirty = function () {
            return window.location.pathname === '/user/settings' && typeof hasFormChanges === 'function' && hasFormChanges();
        };

        // Discard/Save disabled when not dirty; enable on any form change
        updateSettingsActionButtons();

        // Clear password fields after browser autofill completes (browsers fill after DOMContentLoaded;
        // 150 ms is enough for autofill to run but before the user interacts with the Security tab).
        // Re-baseline originalValues so autofill does not leave a spuriously dirty state.
        setTimeout(() => {
            ['currentPassword', 'newPassword', 'confirmPassword'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.value = '';
            });
            originalValues = JSON.parse(JSON.stringify(getCurrentFormValues()));
            updateSettingsActionButtons();
        }, 150);

        // Bind event delegation once (guard against re-navigation rebind)
        const settingsContainer = document.querySelector('.local-user-profile');
        if (settingsContainer && !settingsContainer.dataset.eventsBound) {
            settingsContainer.addEventListener('input', (e) => {
                syncSettingsPluginFieldFromElement(e.target);
                updateSettingsActionButtons();
            });
            settingsContainer.addEventListener('change', (e) => {
                // W-129/W-175: Preview theme immediately when preferences.theme changes.
                const path = e.target?.getAttribute?.('data-path');
                if (path === 'preferences.theme') {
                    applyThemePreview(e.target.value);
                }
                syncSettingsPluginFieldFromElement(e.target);
                updateSettingsActionButtons();
            });
            settingsContainer.dataset.eventsBound = '1';
        }
    }

    // W-107: Sync plugin card input value to currentUserData (user settings)
    function syncSettingsPluginFieldFromElement(el) {
        if (!el || !el.getAttribute) return;
        const blockKey = el.getAttribute('data-plugin-block');
        const fieldKey = el.getAttribute('data-plugin-field');
        if (!blockKey || !fieldKey) return;

        let value;
        if (el.type === 'checkbox') {
            value = el.checked;
        } else if (el.type === 'number') {
            const v = parseFloat(el.value);
            value = isNaN(v) ? el.value : v;
        } else if (el.getAttribute('data-taginput') !== null) {
            // W-170: tagInput stores comma-separated string; parseValue returns string[]
            value = jPulse.UI.input.tagInput.parseValue(el.value);
        } else {
            value = el.value;
        }

        if (!currentUserData[blockKey]) currentUserData[blockKey] = {};
        currentUserData[blockKey][fieldKey] = value;
    }

    let originalValues = {};
    let schemaMetadata = {};  // W-107: Schema extensions metadata (plugins)
    let coreSchema = {};      // W-175: Core display schema (profile, preferences)
    let currentUserData = {}; // W-107: Current user data for plugin cards
    let pluginConfig = {};    // W-107: Plugin config from database
    let originalThemePreview = null; // Theme before any preview changes in current edit session
    let settingsTabsHandle = null; // W-171: Tabs registration handle; null = tabs not yet built

    const themeColorSchemes = (function buildThemeSchemeMap() {
        const map = {};
        {{#each appConfig.system.themes}}
            map['{{this.name}}'] = '{{this.colorScheme}}';
        {{/each}}
        return map;
    })();

    function applyThemePreview(themeId) {
        const id = String(themeId || '').trim();
        if (!id.match(/^[a-zA-Z0-9_-]+$/)) return;

        document.documentElement.setAttribute('data-theme', id);

        const themeLink = Array.from(document.querySelectorAll('link[rel="stylesheet"]'))
            .find(l => (l.getAttribute('href') || '').startsWith('/themes/') || (l.href || '').includes('/themes/'));

        if (themeLink) {
            themeLink.setAttribute('href', `/themes/${id}.css?t=${Date.now()}`);
        }

        const scheme = themeColorSchemes[id] || (id === 'dark' ? 'dark' : 'light');
        const prismLink = Array.from(document.querySelectorAll('link[rel="stylesheet"]'))
            .find(l => (l.getAttribute('href') || '').startsWith('/common/prism/prism-') || (l.href || '').includes('/common/prism/prism-'));

        if (prismLink && (scheme === 'light' || scheme === 'dark')) {
            prismLink.setAttribute('href', `/common/prism/prism-${scheme}.css?t=${Date.now()}`);
        }
    }

    // Warn user when navigating away with unsaved changes (W-161: always-edit, no editMode)
    // Only run on settings route; after SPA navigate away the form is gone and discard already cleared dirty
    window.addEventListener('beforeunload', (event) => {
        if (window.location.pathname !== '/user/settings') return;
        if (hasFormChanges()) {
            event.preventDefault();
            event.returnValue = true;
            return true;
        }
    });

    // Coming back via browser Back (e.g. from docs): page may be restored from bfcache with old dirty state.
    // Clear it so reload doesn't prompt and user sees last-saved state.
    window.addEventListener('pageshow', (event) => {
        if (event.persisted && window.location.pathname === '/user/settings' && typeof revertChanges === 'function') {
            revertChanges({ skipConfirm: true });
        }
    });

    // W-175: Get current form values as an object (for comparison and save).
    // Core fields read via per-panel getAllValues; password + plugin fields appended.
    // Per-panel scope is precise and avoids accidentally reading unrelated data-path fields.
    function getCurrentFormValues() {
        const profilePanel = document.getElementById('panel-profile');
        const prefPanel = document.getElementById('panel-preferences');
        const profileRaw = profilePanel ? jPulse.UI.input.getAllValues(profilePanel) : {};
        const prefRaw = prefPanel ? jPulse.UI.input.getAllValues(prefPanel) : {};
        const values = {
            profile: profileRaw.profile || {},
            preferences: prefRaw.preferences || {},
            currentPassword: document.getElementById('currentPassword')?.value || '',
            newPassword: document.getElementById('newPassword')?.value || '',
            confirmPassword: document.getElementById('confirmPassword')?.value || ''
        };
        // Include plugin data
        for (const key of Object.keys(schemaMetadata)) {
            if (currentUserData[key] !== undefined) {
                values[key] = currentUserData[key];
            }
        }
        return values;
    }

    function hasFormChanges() {
        return !jPulse.utils.deepEqual(getCurrentFormValues(), originalValues);
    }

    // Enable/disable Discard and Save based on dirty state (disabled on load when not dirty)
    function updateSettingsActionButtons() {
        const dirty = hasFormChanges();
        const discardBtn = document.getElementById('discardBtn');
        const saveBtn = document.getElementById('saveBtn');
        if (discardBtn) discardBtn.disabled = !dirty;
        if (saveBtn) saveBtn.disabled = !dirty;
    }

    // W-161: Revert to last saved state (stay on page); no edit/view mode
    // W-171: No collapsible; just clear password fields directly
    // skipConfirm: true = revert without dialog (e.g. when SPA navigation already confirmed discard)
    async function revertChanges(options = {}) {
        const { revertTheme = true, skipConfirm = false } = options;
        if (!skipConfirm && hasFormChanges()) {
            const result = await jPulse.UI.confirmDialog({
                title: `{{i18n.view.user.settings.discardChangesTitle}}`,
                message: `{{i18n.view.user.settings.discardChangesMessage}}`,
                buttons: [`{{i18n.view.user.settings.keepEditing}}`, `{{i18n.view.user.settings.discardChanges}}`]
            });
            if (result.button === `{{i18n.view.user.settings.keepEditing}}`) {
                return;
            }
        }

        // W-175: Restore core fields via per-panel setAllValues.
        // Include username/email in the profile panel data to preserve those readonly fields.
        const profilePanel = document.getElementById('panel-profile');
        const prefPanel = document.getElementById('panel-preferences');
        if (profilePanel) {
            jPulse.UI.input.setAllValues(profilePanel, {
                username: currentUserData.username || '',
                email: currentUserData.email || '',
                profile: originalValues.profile || {}
            });
        }
        if (prefPanel) jPulse.UI.input.setAllValues(prefPanel, { preferences: originalValues.preferences || {} });

        // Restore plugin block data from baseline
        for (const key of Object.keys(schemaMetadata)) {
            if (originalValues[key] !== undefined) {
                currentUserData[key] = originalValues[key];
            }
        }

        // Re-render plugin panel content (tabs structure unchanged)
        renderPluginCards(false);

        if (revertTheme) {
            // W-175: theme select has no id="theme"; use data-path (same as loadSettingsThemes)
            const themeField = document.querySelector('[data-path="preferences.theme"]');
            const revertThemeId = themeField ? (themeField.value || originalThemePreview || 'light') : (originalThemePreview || 'light');
            applyThemePreview(revertThemeId);
        }

        // Clear password fields (no collapsible to close in W-171)
        ['currentPassword', 'newPassword', 'confirmPassword'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        updateSettingsActionButtons();
    }

    async function saveProfile() {
        // W-171: Password change detected by non-empty NEW password field.
        // Checking only newPassword (not currentPassword) avoids false positives when the browser
        // pre-fills currentPassword via saved credentials without the user's intent.
        const currentPassword = document.getElementById('currentPassword').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        const isChangingPassword = !!(newPassword || confirmPassword);

        // W-175: Collect profile + preferences via per-panel getAllValues; plugin data appended
        const profilePanel = document.getElementById('panel-profile');
        const prefPanel = document.getElementById('panel-preferences');
        const profileRaw = profilePanel ? jPulse.UI.input.getAllValues(profilePanel) : {};
        const prefRaw = prefPanel ? jPulse.UI.input.getAllValues(prefPanel) : {};
        const profileData = {
            profile: profileRaw.profile || {},
            preferences: prefRaw.preferences || {}
        };

        // W-107: Include plugin data from schema extensions
        for (const blockKey of Object.keys(schemaMetadata)) {
            if (currentUserData[blockKey] !== undefined) {
                profileData[blockKey] = currentUserData[blockKey];
            }
        }

        try {
            // Always save profile and preferences first
            const profileResult = await jPulse.api.put('/api/1/user', profileData);

            if (!profileResult.success) {
                jPulse.UI.toast.error(profileResult.error || `{{i18n.view.user.settings.failedToUpdateProfile}}`);
                return;
            }

            // If user wants to change password, handle that too
            if (isChangingPassword) {

                // Validate password fields
                if (!currentPassword || !newPassword || !confirmPassword) {
                    jPulse.UI.toast.error(`{{i18n.view.user.settings.allPasswordFieldsRequired}}`);
                    return;
                }

                if (newPassword !== confirmPassword) {
                    jPulse.UI.toast.error(`{{i18n.view.user.settings.passwordsDoNotMatch}}`);
                    return;
                }

                if (newPassword.length < 8) {
                    jPulse.UI.toast.error(`{{i18n.view.user.settings.passwordTooShort}}`);
                    return;
                }

                // Save password
                const passwordData = {
                    currentPassword: currentPassword,
                    newPassword: newPassword
                };

                const passwordResult = await jPulse.api.put('/api/1/user/password', passwordData);

                if (!passwordResult.success) {
                    jPulse.UI.toast.error(passwordResult.error || `{{i18n.view.user.settings.failedToUpdatePassword}}`);
                    return;
                }
            }

            // Success - show appropriate message
            const successMessage = isChangingPassword
                ? `{{i18n.view.user.settings.profileAndPasswordUpdatedSuccess}}`
                : `{{i18n.view.user.settings.profileUpdatedSuccess}}`;

            jPulse.UI.toast.success(successMessage);

            // W-129: Apply updated theme immediately (no page reload needed)
            const newThemeRaw = profileData?.preferences?.theme || 'light';
            const newTheme = (/^[a-zA-Z0-9_-]+$/.test(newThemeRaw) ? newThemeRaw : 'light');
            const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
            if (newTheme !== currentTheme) {
                applyThemePreview(newTheme);
            }
            originalThemePreview = newTheme;

            await loadSettingsProfile();
            originalValues = JSON.parse(JSON.stringify(getCurrentFormValues()));

            // Clear password fields (W-171: no collapsible)
            ['currentPassword', 'newPassword', 'confirmPassword'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.value = '';
            });
            updateSettingsActionButtons();

        } catch (error) {
            jPulse.UI.toast.error(`{{i18n.view.user.settings.networkError}}`.replace('%ERROR%', error.message));
        }
    }

    async function loadSettingsProfile() {
        try {
            // W-107/W-175: Request user data with schema extensions + core display schema
            const result = await jPulse.api.get('/api/1/user?includeSchema=1');
            if (result.success && result.data) {
                const user = result.data;
                currentUserData = user;  // W-107: Store for plugin cards

                // W-107: Store plugin schema metadata if provided
                if (result.schema) {
                    schemaMetadata = result.schema;
                }
                // W-175: Store core display schema
                if (result.coreSchema) {
                    coreSchema = result.coreSchema;
                }

                // W-175: Render or repopulate core schema panels
                if (settingsTabsHandle === null) {
                    // First init: build panel content (panels exist in DOM, tabs not yet registered)
                    // profile: blockData=user.profile, rootData=user (for username/email dataPath fields)
                    renderCoreSchemaBlock('profile', coreSchema.profile, user.profile || {}, 'user', user);
                    renderCoreSchemaBlock('preferences', coreSchema.preferences, user.preferences || {}, 'user');
                } else {
                    // Re-nav: panels inside .jp-tabs-panels — repopulate via per-panel setAllValues.
                    // profile panel: include username/email (readonly, dataPath fields) to preserve display.
                    const profilePanel = document.getElementById('panel-profile');
                    const prefPanel = document.getElementById('panel-preferences');
                    if (profilePanel) {
                        jPulse.UI.input.setAllValues(profilePanel, {
                            username: user.username || '',
                            email: user.email || '',
                            profile: user.profile || {}
                        });
                    }
                    if (prefPanel) {
                        jPulse.UI.input.setAllValues(prefPanel, { preferences: user.preferences || {} });
                    }
                }

                // W-171: Update page header user info (name, avatar initials, status badge)
                const headerName = document.getElementById('settingsNameHeader');
                if (headerName) {
                    headerName.textContent = [user.profile?.firstName || '', user.profile?.lastName || ''].filter(Boolean).join(' ');
                }
                const headerAvatar = document.getElementById('settingsAvatarHeader');
                if (headerAvatar) {
                    const f = (user.profile?.firstName || '').charAt(0).toUpperCase();
                    const l = (user.profile?.lastName || '').charAt(0).toUpperCase();
                    const initials = (f + l) || headerAvatar.textContent;
                    headerAvatar.textContent = initials;
                }
                const statusBadge = document.getElementById('settingsStatusHeader');
                if (statusBadge && user.status) {
                    statusBadge.textContent = user.status;
                    statusBadge.className = `jp-status-badge jp-status-${user.status} local-header-status`;
                }

                // W-107: Render plugin cards (build panels on first init, repopulate on re-nav/revert)
                await loadPluginConfig();
                renderPluginCards(settingsTabsHandle === null);
            } else {
                jPulse.UI.toast.error(result.error || `{{i18n.view.user.settings.failedToLoadProfile}}`);
            }
        } catch (error) {
            jPulse.UI.toast.error(`{{i18n.view.user.settings.networkErrorLoadingProfile}}`.replace('%ERROR%', error.message));
        }
    }

    // W-107: Load plugin configuration from database
    // TODO: Implement proper /api/1/plugin/config endpoint in future
    async function loadPluginConfig() {
        // For now, plugin config-based showIf conditions will use empty config
        // This means actions with showIf: { config: '...' } will default to hidden
        pluginConfig = {};
    }

    // W-175: Render a core display schema block into its panel element.
    // blockKey: 'profile' or 'preferences'
    // blockDef: coreSchema[blockKey] — the block definition
    // blockData: data for fields WITHOUT dataPath (e.g. user.profile for profile block)
    // context: 'user' or 'admin'
    // rootData: (optional) full user object — used for fields WITH dataPath (username, email)
    // Fields with fullWidth: true render outside the grid row (full width).
    // Select inputs render with current value as placeholder; options populated by load*() after.
    function renderCoreSchemaBlock(blockKey, blockDef, blockData, context, rootData) {
        const panel = document.getElementById('panel-' + blockKey);
        if (!panel || !blockDef) return;
        const isAdmin = context === 'admin';
        const esc = (v) => jPulse.string.escapeHtml(v !== null && v !== undefined ? String(v) : '');
        const maxCols = Math.max(1, parseInt(blockDef._meta?.[isAdmin ? 'adminCard' : 'userCard']?.maxColumns, 10) || 1);
        const useGrid = maxCols >= 2;

        const visibleFields = [];
        for (const [fieldKey, fieldDef] of Object.entries(blockDef)) {
            if (fieldKey === '_meta') continue;
            const ctxDef = isAdmin ? fieldDef.adminCard : fieldDef.userCard;
            if (!ctxDef?.visible) continue;
            visibleFields.push([fieldKey, fieldDef, ctxDef]);
        }

        let bodyHtml = '';
        let gridBuf = [];

        const flushGrid = () => {
            if (!gridBuf.length) return;
            bodyHtml += '<div class="jp-form-grid">' + gridBuf.join('') + '</div>';
            gridBuf = [];
        };

        for (const [fieldKey, fieldDef, ctxDef] of visibleFields) {
            const isReadOnly = ctxDef.readOnly === true;
            const label = esc(fieldDef.label || fieldKey);
            const inputType = fieldDef.inputType || 'text';
            const dataPath = fieldDef.dataPath || (blockKey + '.' + fieldKey);
            const fieldId = 'core-' + dataPath.replace(/\./g, '-');
            // dataPath fields (username, email) live at root; others live in blockData
            const src = fieldDef.dataPath ? (rootData || blockData) : blockData;
            const rawKey = fieldDef.dataPath ? fieldDef.dataPath : fieldKey;
            const rawVal = src[rawKey] !== undefined ? src[rawKey] : (fieldDef.default !== undefined ? fieldDef.default : '');
            const escapedVal = esc(rawVal);
            const readonlyClass = isReadOnly ? ' jp-read-only-field' : '';
            const readonlyAttr = isReadOnly ? ' readonly' : '';
            const fullWidth = !!fieldDef.fullWidth;

            let inputHtml;
            if (inputType === 'select') {
                // Options populated post-render by loadSettingsLanguages / loadSettingsThemes
                inputHtml = `<select id="${fieldId}" name="${fieldKey}" class="jp-form-select" data-path="${dataPath}"><option value="${escapedVal}" selected>${escapedVal}</option></select>`;
            } else {
                inputHtml = `<input type="text" id="${fieldId}" name="${fieldKey}" class="jp-form-input${readonlyClass}" data-path="${dataPath}" value="${escapedVal}"${readonlyAttr}>`;
            }

            const groupHtml = `<div class="jp-form-group"><label for="${fieldId}" class="jp-form-label">${label}</label>${inputHtml}</div>`;

            if (useGrid && !fullWidth) {
                gridBuf.push(groupHtml);
            } else {
                flushGrid();
                bodyHtml += groupHtml;
            }
        }
        flushGrid();

        panel.innerHTML = '<div class="jp-card jp-schema-section">' + bodyHtml + '</div>';
    }

    // W-171/W-175: Build tabs registration config and call tabs.register().
    // Core tabs come from coreSchema (profile, preferences); Security is hardcoded; plugin tabs appended.
    // Called once on first init; subsequent navigations reuse the existing tabs structure.
    function buildSettingsTabs() {
        const tabs = [];

        // W-175: Core blocks from coreSchema, sorted by userCard.order
        Object.entries(coreSchema)
            .filter(([, def]) => def._meta?.userCard?.visible)
            .sort((a, b) => (a[1]._meta?.userCard?.order || 999) - (b[1]._meta?.userCard?.order || 999))
            .forEach(([blockKey, blockDef]) => {
                const meta = blockDef._meta.userCard;
                const tab = { id: `tab-${blockKey}`, label: meta.label || blockKey, panelId: `panel-${blockKey}` };
                const rawIcon = meta.icon;
                if (rawIcon !== undefined && rawIcon !== null && String(rawIcon).trim() !== '') {
                    tab.icon = String(rawIcon).trim();
                }
                tabs.push(tab);
            });

        // Security: hardcoded after core blocks, before plugins
        tabs.push({ id: 'tab-security', label: '{{i18n.view.user.settings.security}}', panelId: 'panel-security' });

        // Plugin blocks from schemaMetadata, sorted by userCard.order
        Object.entries(schemaMetadata)
            .filter(([, def]) => def._meta?.userCard?.visible)
            .sort((a, b) => (a[1]._meta?.userCard?.order || 999) - (b[1]._meta?.userCard?.order || 999))
            .forEach(([blockKey, blockDef]) => {
                const meta = blockDef._meta.userCard;
                const tab = { id: `tab-plugin-${blockKey}`, label: meta.label || blockKey, panelId: `panel-plugin-${blockKey}` };
                const rawIcon = meta.icon;
                if (rawIcon !== undefined && rawIcon !== null && String(rawIcon).trim() !== '') {
                    tab.icon = String(rawIcon).trim();
                }
                tabs.push(tab);
            });

        return jPulse.UI.tabs.register('settingsTabs', {
            tabs,
            slideAnimation: true,
            responsive: 'scroll'
        });
    }

    // W-107: Render plugin cards based on schema extensions
    // W-171: buildPanels=true creates panel elements in staging area (first init before tabs.register());
    //        buildPanels=false re-renders content in existing panels (re-nav or revert, no DOM rebuild)
    function renderPluginCards(buildPanels = false) {
        if (!schemaMetadata || Object.keys(schemaMetadata).length === 0) return;

        // Sort plugins by order - use userCard for user's own profile
        const sortedBlocks = Object.entries(schemaMetadata)
            .filter(([, blockDef]) => blockDef._meta?.userCard?.visible)
            .sort((a, b) => (a[1]._meta?.userCard?.order || 999) - (b[1]._meta?.userCard?.order || 999));

        if (buildPanels) {
            // First init: create plugin panel elements in staging area before tabs.register()
            const staging = document.getElementById('settingsPluginPanels');
            if (!staging) return;
            staging.innerHTML = '';
            sortedBlocks.forEach(([blockKey, blockDef]) => {
                const panel = document.createElement('div');
                panel.id = `panel-plugin-${blockKey}`;
                panel.className = 'jp-panel';
                panel.innerHTML = buildPluginPanelContent(blockKey, blockDef);
                staging.appendChild(panel);
            });
            // Panels will be moved into .jp-tabs-panels by the upcoming tabs.register() call
        } else {
            // Re-nav or revert: update content in existing panels (already inside .jp-tabs-panels)
            sortedBlocks.forEach(([blockKey, blockDef]) => {
                const panel = document.getElementById(`panel-plugin-${blockKey}`);
                if (panel) {
                    panel.innerHTML = buildPluginPanelContent(blockKey, blockDef);
                }
            });
            // Re-initialize widgets in updated panels
            const tabsEl = document.getElementById('settingsTabs');
            if (tabsEl) jPulse.UI.input.initAll(tabsEl);
        }
    }

    // W-171: Build HTML content for a single plugin panel (used by renderPluginCards)
    function buildPluginPanelContent(blockKey, blockDef) {
        const cardConfig = blockDef._meta.userCard;
        const userData = currentUserData[blockKey] || {};
        const description = cardConfig.description || '';
        const actionsHtml = renderCardActions(blockKey, cardConfig.actions || [], userData);
        const fieldsHtml = renderCardFields(blockKey, blockDef, userData);

        return `<div class="jp-card local-plugin-card">` +
            (description ? `<div class="local-plugin-card-description">${jPulse.string.escapeHtml(description)}</div>` : '') +
            `<div class="local-plugin-field-grid">${fieldsHtml}</div>` +
            (actionsHtml ? `<div class="local-plugin-card-actions">${actionsHtml}</div>` : '') +
            `</div>`;
    }

    // Parse CSS color strings to RGB (supports #RGB, #RRGGBB, rgb(), rgba()).
    function parseCssColor(color) {
        if (!color) return null;
        const c = String(color).trim();

        // #RGB or #RRGGBB
        const hexMatch = c.match(/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/);
        if (hexMatch) {
            let hex = hexMatch[1];
            if (hex.length === 3) {
                hex = hex.split('').map(ch => ch + ch).join('');
            }
            const r = parseInt(hex.slice(0, 2), 16);
            const g = parseInt(hex.slice(2, 4), 16);
            const b = parseInt(hex.slice(4, 6), 16);
            return { r, g, b };
        }

        // rgb()/rgba()
        const rgbMatch = c.match(/^rgba?\(\s*([0-9]{1,3})\s*,\s*([0-9]{1,3})\s*,\s*([0-9]{1,3})(?:\s*,\s*([0-9.]+))?\s*\)$/);
        if (rgbMatch) {
            const r = Math.min(255, Math.max(0, parseInt(rgbMatch[1], 10)));
            const g = Math.min(255, Math.max(0, parseInt(rgbMatch[2], 10)));
            const b = Math.min(255, Math.max(0, parseInt(rgbMatch[3], 10)));
            return { r, g, b };
        }

        return null;
    }

    // WCAG relative luminance for sRGB.
    function getRelativeLuminance(rgb) {
        const toLinear = (v) => {
            const s = v / 255;
            return s <= 0.04045 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
        };
        const r = toLinear(rgb.r);
        const g = toLinear(rgb.g);
        const b = toLinear(rgb.b);
        return 0.2126 * r + 0.7152 * g + 0.0722 * b;
    }

    // W-107: Render card action buttons
    function renderCardActions(blockKey, actions, userData) {
        if (!actions || actions.length === 0) return '';

        return actions
            .filter(action => evaluateShowIf(action.showIf, userData, blockKey))
            .map(action => {
                const style = action.style || 'secondary';
                const icon = action.icon ? `${action.icon} ` : '';
                const btnClass = `jp-btn jp-btn-${style} jp-btn-sm`;
                return `<button class="${btnClass}" onclick="handlePluginAction('${blockKey}', ${JSON.stringify(action).replace(/'/g, "\\'").replace(/"/g, '&quot;')})">${icon}${action.label}</button>`;
            })
            .join('');
    }

    // W-107: Evaluate showIf condition
    function evaluateShowIf(showIf, userData, blockKey) {
        if (!showIf) return true;

        // Simple conditions
        if (showIf === 'always') return true;
        if (showIf === 'hasValue') return false; // For action buttons, default to true if no showIf

        // Field-based condition: { field: 'mfa.enabled', equals: true }
        if (showIf.field) {
            let value = getSettingsNestedValue(currentUserData, showIf.field);

            // Apply default from schema if value is undefined
            if (value === undefined) {
                const parts = showIf.field.split('.');
                if (parts.length >= 2) {
                    const schemaBlock = schemaMetadata[parts[0]];
                    const fieldDef = schemaBlock?.[parts[1]];
                    if (fieldDef?.default !== undefined) {
                        value = fieldDef.default;
                    }
                }
            }

            if (showIf.equals !== undefined) {
                return value === showIf.equals;
            }
            if (showIf.condition === 'exists') {
                return value !== null && value !== undefined;
            }
            if (showIf.condition === 'gt' && showIf.value !== undefined) {
                return value > showIf.value;
            }
            return false;
        }

        // Config-based condition: { config: 'auth-mfa.allowUserDisable', equals: true }
        if (showIf.config) {
            const value = getSettingsNestedValue(pluginConfig, showIf.config);
            return value === showIf.equals;
        }

        // All condition: { all: [...conditions] }
        if (showIf.all && Array.isArray(showIf.all)) {
            return showIf.all.every(cond => evaluateShowIf(cond, userData, blockKey));
        }

        // Any condition: { any: [...conditions] }
        if (showIf.any && Array.isArray(showIf.any)) {
            return showIf.any.some(cond => evaluateShowIf(cond, userData, blockKey));
        }

        return true;
    }

    // W-107: Get nested value from object using dot notation
    function getSettingsNestedValue(obj, path) {
        if (!obj || !path) return undefined;
        return path.split('.').reduce((acc, part) => acc?.[part], obj);
    }

    // W-107: Set nested value in object using dot notation
    function setSettingsNestedValue(obj, path, value) {
        const parts = path.split('.');
        const last = parts.pop();
        const target = parts.reduce((acc, part) => {
            if (acc[part] === undefined) acc[part] = {};
            return acc[part];
        }, obj);
        target[last] = value;
    }

    // W-175: Boolean / checkbox plugin fields: checkbox first, label next (not label column | checkbox column).
    // Schema may use type: boolean with inputType: 'boolean' (redundant); exclude future non-checkbox widgets.
    function isPluginCardCheckboxField(fieldDef) {
        if (fieldDef.inputType === 'switch') return false;
        return fieldDef.inputType === 'checkbox' || fieldDef.type === 'boolean';
    }

    // W-107: Render card fields (display-only or editable based on userCard.readOnly)
    function renderCardFields(blockKey, blockDef, userData) {
        const fields = [];

        for (const [fieldKey, fieldDef] of Object.entries(blockDef)) {
            if (fieldKey === '_meta') continue;
            if (!fieldDef.userCard?.visible) continue;  // Use userCard for user profile

            // Get value with fallback to default from schema
            let value = userData[fieldKey];
            if (value === undefined && fieldDef.default !== undefined) {
                value = fieldDef.default;
            }

            // Check showIf
            const showIf = fieldDef.showIf;
            if (showIf === 'hasValue' && (value === null || value === undefined)) {
                continue;
            }
            if (typeof showIf === 'object' && !evaluateShowIf(showIf, userData, blockKey)) {
                continue;
            }

            const label = fieldDef.label || fieldKey;
            const isEditable = fieldDef.userCard?.readOnly !== true;
            const fieldId = `settings-plugin-${blockKey}-${fieldKey}`;

            if (isEditable && isPluginCardCheckboxField(fieldDef)) {
                const checked = value ? 'checked' : '';
                const dataAttrs = `data-plugin-block="${jPulse.string.escapeHtml(blockKey)}" data-plugin-field="${jPulse.string.escapeHtml(fieldKey)}"`;
                fields.push(`
                    <div class="local-plugin-field-checkbox jp-checkbox-group">
                        <input type="checkbox" id="${fieldId}" class="jp-form-input" ${dataAttrs} ${checked}>
                        <label for="${fieldId}">${jPulse.string.escapeHtml(label)}</label>
                    </div>
                `);
            } else if (isEditable) {
                const inputHtml = renderSettingsPluginFieldInput(blockKey, fieldKey, fieldDef, value, fieldId);
                fields.push(`
                    <div class="local-plugin-field-label"><label for="${fieldId}">${jPulse.string.escapeHtml(label)}:</label></div>
                    <div class="local-plugin-field-value">${inputHtml}</div>
                `);
            } else {
                const displayValue = formatSettingsFieldValue(value, fieldDef);
                fields.push(`
                    <div class="local-plugin-field-label">${jPulse.string.escapeHtml(label)}:</div>
                    <div class="local-plugin-field-value">${displayValue}</div>
                `);
            }
        }

        return fields.join('');
    }

    // W-107: Render editable input for plugin card field (user settings)
    function renderSettingsPluginFieldInput(blockKey, fieldKey, fieldDef, value, fieldId) {
        const inputType = fieldDef.inputType || fieldDef.type || 'string';
        const esc = (v) => (v === null || v === undefined ? '' : jPulse.string.escapeHtml(String(v)));
        const dataAttrs = `data-plugin-block="${jPulse.string.escapeHtml(blockKey)}" data-plugin-field="${jPulse.string.escapeHtml(fieldKey)}"`;

        if (isPluginCardCheckboxField(fieldDef)) {
            const checked = value ? 'checked' : '';
            return `<input type="checkbox" id="${fieldId}" class="jp-form-input" ${dataAttrs} ${checked}>`;
        }
        if (inputType === 'textarea') {
            const rows = fieldDef.rows || 3;
            return `<textarea id="${fieldId}" name="${fieldKey}" rows="${rows}" class="jp-form-input jp-form-textarea" ${dataAttrs}>${esc(value)}</textarea>`;
        }
        if (inputType === 'select' && fieldDef.options) {
            const opts = (fieldDef.options || []).map(opt => {
                const ov = typeof opt === 'object' ? opt.value : opt;
                const ol = typeof opt === 'object' ? (opt.label || opt.value) : opt;
                const sel = value === ov ? ' selected' : '';
                return `<option value="${esc(ov)}"${sel}>${esc(ol)}</option>`;
            }).join('');
            return `<select id="${fieldId}" name="${fieldKey}" class="jp-form-select" ${dataAttrs}>${opts}</select>`;
        }
        // W-170: slider widget — type=number keeps value store numeric; data-slider* attrs drive the widget UI
        if (inputType === 'slider') {
            const min  = fieldDef.min     != null ? ` data-slider-min="${fieldDef.min}"`                   : '';
            const max  = fieldDef.max     != null ? ` data-slider-max="${fieldDef.max}"`                   : '';
            const step = fieldDef.step    != null ? ` data-slider-step="${fieldDef.step}"`                 : '';
            const def  = fieldDef.default != null ? ` data-slider-default="${fieldDef.default}"`           : '';
            const suf  = fieldDef.suffix  != null ? ` data-slider-suffix="${esc(fieldDef.suffix)}"`        : '';
            const numVal = (value === null || value === undefined) ? '' : esc(value);
            return `<input type="number" id="${fieldId}" name="${fieldKey}" value="${numVal}" class="jp-form-input" data-slider${min}${max}${step}${def}${suf} ${dataAttrs}>`;
        }
        // W-170: tagInput widget — value stored as comma-separated string; parseValue returns string[]
        if (inputType === 'tagInput') {
            const arr = Array.isArray(value) ? value : (value ? String(value).split(',').map(s => s.trim()) : []);
            const formatted = jPulse.UI.input.tagInput.formatValue(arr);
            return `<input type="text" id="${fieldId}" name="${fieldKey}" value="${esc(formatted)}" class="jp-form-input" data-taginput ${dataAttrs}>`;
        }
        const type = (inputType === 'number' || fieldDef.type === 'number') ? 'number' : 'text';
        const numVal = (type === 'number' && (value === null || value === undefined)) ? '' : esc(value);
        return `<input type="${type}" id="${fieldId}" name="${fieldKey}" value="${numVal}" class="jp-form-input" ${dataAttrs}>`;
    }

    // W-107: Format field value based on displayAs
    function formatSettingsFieldValue(value, fieldDef) {
        const displayAs = fieldDef.displayAs;

        if (value === null || value === undefined) {
            return '<span class="jp-text-muted">—</span>';
        }

        switch (displayAs) {
            case 'badge':
                if (typeof value === 'boolean') {
                    const badgeClass = value ? 'local-plugin-badge-success' : 'local-plugin-badge-danger';
                    const badgeText = value ? '✅ Enabled' : '❌ Disabled';
                    return `<span class="local-plugin-badge ${badgeClass}">${badgeText}</span>`;
                }
                return `<span class="local-plugin-badge local-plugin-badge-info">${value}</span>`;

            case 'date':
                if (!value) return '<span class="jp-text-muted">—</span>';
                return jPulse.date.formatLocalDate(value);

            case 'datetime':
                if (!value) return '<span class="jp-text-muted">—</span>';
                return jPulse.date.formatLocalDateAndTime(value);

            case 'count':
                if (Array.isArray(value)) {
                    return `${value.length} remaining`;
                }
                return String(value);

            default:
                if (typeof value === 'boolean') {
                    return value ? '{{i18n.view.user.settings.yes}}' : '{{i18n.view.user.settings.no}}';
                }
                if (Array.isArray(value)) {
                    return value.join(', ');
                }
                return String(value);
        }
    }

    // W-107: Handle plugin action button click
    async function handlePluginAction(blockKey, action) {
        // Parse action if it's a string (from HTML attribute)
        if (typeof action === 'string') {
            action = JSON.parse(action.replace(/&quot;/g, '"'));
        }

        // Show confirmation dialog if required
        if (action.confirm) {
            const result = await jPulse.UI.confirmDialog({
                title: action.label,
                message: action.confirm,
                buttons: ['{{i18n.view.user.settings.cancel}}', '{{i18n.view.user.settings.continue}}']
            });
            if (result.button !== '{{i18n.view.user.settings.continue}}') return;
        }

        // Handle different action types (W-161: always edit, no toggle)
        if (action.setFields) {
            // Apply setFields to currentUserData (local modification)
            for (const [path, value] of Object.entries(action.setFields)) {
                setSettingsNestedValue(currentUserData, path, value);
            }

            // Re-render the plugin panel content (W-171: use repopulate mode)
            renderPluginCards(false);

            // Show toast
            if (action.toast) {
                jPulse.UI.toast.info(action.toast);
            }
        } else if (action.navigate) {
            if (hasFormChanges()) {
                const result = await jPulse.UI.confirmDialog({
                    title: `{{i18n.view.user.settings.unsavedChangesTitle}}`,
                    message: `{{i18n.view.user.settings.unsavedChangesMessage}}`,
                    buttons: [`{{i18n.view.user.settings.cancel}}`, `{{i18n.view.user.settings.saveAndContinue}}`]
                });
                if (result.button === `{{i18n.view.user.settings.cancel}}`) return;
                await saveProfile();
            }
            window.location.href = action.navigate;
        } else if (action.handler) {
            // Call registered handler
            const handler = window.jPulse?.schemaHandlers?.[action.handler];
            if (handler) {
                const result = await handler(currentUserData, action);
                if (result?.refresh) {
                    await loadSettingsProfile();
                }
            } else {
                console.error(`- jPulse: Handler not found: ${action.handler}`);
                jPulse.UI.toast.error('{{i18n.view.user.settings.handlerNotAvailable}}'.replace('%HANDLER%', action.handler));
            }
        }
    }

    async function loadSettingsLanguages() {
        try {
            const response = await jPulse.api.get('/api/1/auth/languages');

            if (response.success) {
                // W-175: select rendered by renderCoreSchemaBlock; find by data-path
                const languageSelect = document.querySelector('[data-path="preferences.language"]');
                if (!languageSelect) return;
                const currentValue = languageSelect.value;

                languageSelect.innerHTML = '';

                const languages = response.data;
                if (Array.isArray(languages)) {
                    languages.forEach(([code, name]) => {
                        const option = document.createElement('option');
                        option.value = code;
                        option.textContent = name;
                        languageSelect.appendChild(option);
                    });
                } else {
                    console.error('- jPulse: Languages data is not an array:', languages);
                    jPulse.UI.toast.error('{{i18n.view.user.settings.invalidLanguageDataFormat}}');
                }

                languageSelect.value = currentValue;
            } else {
                const errorMsg = response.error || '{{i18n.view.user.settings.unknownError}}';
                jPulse.UI.toast.error('{{i18n.view.user.settings.failedToLoadLanguageOptions}}'.replace('%ERROR%', errorMsg));
            }
        } catch (error) {
            console.error('- jPulse: Failed to load languages:', error);
            jPulse.UI.toast.error('{{i18n.view.user.settings.failedToLoadLanguageOptionsRefresh}}');
        }
    }

    async function loadSettingsThemes() {
        try {
            const response = await jPulse.api.get('/api/1/user/enums?fields=preferences.theme');

            if (response.success && response.data && response.data['preferences.theme']) {
                // W-175: select rendered by renderCoreSchemaBlock; find by data-path
                const themeSelect = document.querySelector('[data-path="preferences.theme"]');
                if (!themeSelect) return;
                const currentValueRaw = themeSelect.value;
                const currentValue = currentValueRaw || 'light';

                themeSelect.innerHTML = '';

                const themes = response.data['preferences.theme'];
                if (Array.isArray(themes)) {
                    themes.forEach(theme => {
                        const option = document.createElement('option');
                        option.value = theme;
                        option.textContent = theme;
                        themeSelect.appendChild(option);
                    });
                } else {
                    console.error('- jPulse: Themes data is not an array:', themes);
                    jPulse.UI.toast.error('{{i18n.view.user.settings.invalidThemeDataFormat}}');
                }

                themeSelect.value = currentValue;
                if (themeSelect.value !== currentValue && themeSelect.options.length > 0) {
                    // If currentValue is not part of the enum list, fall back to first option.
                    themeSelect.selectedIndex = 0;
                }
            } else {
                const errorMsg = response.error || '{{i18n.view.user.settings.unknownError}}';
                jPulse.UI.toast.error('{{i18n.view.user.settings.failedToLoadThemeOptions}}'.replace('%ERROR%', errorMsg));
            }
        } catch (error) {
            console.error('- jPulse: Failed to load themes:', error);
            jPulse.UI.toast.error('{{i18n.view.user.settings.failedToLoadThemeOptionsRefresh}}');
        }
    }
{{/if}}
